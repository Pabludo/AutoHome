# AutoHome Environment Variables
# Copy to .env and fill in real values

# === Idealista Credentials ===
IDEALISTA_EMAIL=your-email@example.com
IDEALISTA_PASSWORD=your-password

# === Clientify API ===
CLIENTIFY_API_TOKEN=your-clientify-api-token
CLIENTIFY_BASE_URL=https://api.clientify.net/v1

# === Inmovilla API (if available) ===
INMOVILLA_API_URL=https://your-instance.inmovilla.com/api
INMOVILLA_API_TOKEN=your-inmovilla-token

# === Database ===
# For SQLite (default): sqlite:///data/AutoHome.db
# For PostgreSQL: postgresql://user:pass@host:5432/AutoHome
DATABASE_URL=sqlite:///data/AutoHome.db

# === Pipeline Settings ===
PIPELINE_INTERVAL_HOURS=6
SCRAPER_DELAY_MIN_SECONDS=2
SCRAPER_DELAY_MAX_SECONDS=5
SCRAPER_MAX_PROPERTIES_PER_SESSION=20

# === Logging ===
LOG_LEVEL=INFO
